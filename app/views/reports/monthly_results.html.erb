<%= turbo_frame_tag 'monthly_results' do %>
    <table style="width: 100%">
    <thead>
        <tr>
            <th>Data</th>
            <th>Operação</th>
            <th>Ativo</th>
            <th class="text-end">Quantidade</th>
            <th class="text-end">Preço</th>
            <th class="text-end">Taxas</th>
            <th class="text-end">Valor Operação</th>
            <th class="text-end">Lucro Líquido</th>
        </tr>
        </thead>
        <tbody>
            <% @results.each do |result| %>
            <tr>
                <td><%= result['trade_date'] %></td>
                <td><%= result['purchase'] == 1 ? "Compra" : "Venda" %></td>
                <td><%= result['ticker'] %></td>
                <td class="text-end"><%= result['quantity'] %></td>
                <td class="text-end"><%= result['asset_price'].to_d %></td>
                <td class="text-end"><%= result['fees'].to_d %></td>
                <td class="text-end"><%= result['total_amount'].to_d %></td>
                <td class="text-end"><%= result['net_profit'].to_d %></td>
            </tr>
            <% end %>
        <tr>
            <td colSpan="7" class="text-end" style="padding: 5px">Total</td>
            <td>
                <%= @total %>
            </td>
        </tr>
        </tbody>
    </table>
<% end %>